{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ConciergeOS",
  "version": "0.0.1",
  "identifier": "com.conciergeos.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {,
    "windows": [
      {
        "title": "ConciergeOS Server",
        "width": 400,
        "height": 500,
        "resizable": true,
        "visible": false,
        "decorations": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "tooltip": "ConciergeOS — Clinic Server",
      "menuOnLeftClick": false
    },
    "security": {
      "csp": "default-src 'self' http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
