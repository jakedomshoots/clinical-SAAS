# Concierge OS Production Environment Configuration
# Copy this file to .env and fill in all required values
# NEVER commit the actual .env file to version control

# =============================================================================
# Application
# =============================================================================
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_URL=https://api.concierge-os.example.com

# Generate with: openssl rand -hex 32
SECRET_KEY=***

# Set to false in production
AUTO_CREATE_SCHEMA=false
ALLOW_SEED_ENDPOINT=false

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# Database
# =============================================================================
# Use AWS RDS or similar managed PostgreSQL
DATABASE_URL=postgresql://user:pass@db.cluster-xxx.us-east-1.rds.amazonaws.com:5432/concierge_os

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# =============================================================================
# Cache
# =============================================================================
# Use AWS ElastiCache Redis with TLS
REDIS_URL=rediss://:password@master.cache.0001.use1.cache.amazonaws.com:6379/0

REDIS_POOL_SIZE=50
REDIS_TIMEOUT=5

# =============================================================================
# Object Storage
# =============================================================================
# Use AWS S3 with KMS encryption
S3_BUCKET=concierge-os-production-assets-123456789
S3_REGION=us-east-1
S3_ENDPOINT_URL=  # Leave empty for AWS S3

# KMS key for envelope encryption
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/xxx

# =============================================================================
# Identity / Authentication
# =============================================================================
# Choose one provider and configure accordingly

# Auth0
IDENTITY_AUTH0_ISSUER_URL=https://concierge-os.us.auth0.com
IDENTITY_AUTH0_CLIENT_ID=***
IDENTITY_AUTH0_CLIENT_SECRET=***
IDENTITY_AUTH0_REDIRECT_URI=https://api.concierge-os.example.com/auth/callback/auth0
IDENTITY_AUTH0_SCOPES=openid profile email
IDENTITY_AUTH0_MFA_REQUIRED=true

# Okta (alternative)
# IDENTITY_OKTA_ISSUER_URL=https://concierge-os.okta.com
# IDENTITY_OKTA_CLIENT_ID=***
# IDENTITY_OKTA_CLIENT_SECRET=***
# IDENTITY_OKTA_REDIRECT_URI=https://api.concierge-os.example.com/auth/callback/okta

# Azure AD (alternative)
# IDENTITY_AZURE_AD_ISSUER_URL=https://login.microsoftonline.com/xxx/v2.0
# IDENTITY_AZURE_AD_CLIENT_ID=***
# IDENTITY_AZURE_AD_CLIENT_SECRET=***

# =============================================================================
# External Integrations
# =============================================================================

# EHR
EHR_API_BASE_URL=***

# Fax Provider
FAX_PROVIDER_API_KEY=***

# Patient Portal
PORTAL_API_BASE_URL=***

# Calendar
CALENDAR_API_BASE_URL=***

# Communications (SMS/Email)
COMMUNICATIONS_PROVIDER=twilio
COMMUNICATIONS_PROVIDER_API_KEY=***
COMMUNICATIONS_WEBHOOK_SECRET=***

# CopilotKit Runtime
COPILOTKIT_RUNTIME_URL=***
COPILOTKIT_API_KEY=***

# Clearinghouse
CLEARINGHOUSE_API_BASE_URL=***
CLEARINGHOUSE_API_KEY=***

# Labs / HIE
LABS_HIE_API_BASE_URL=***

# Payments
PAYMENTS_API_KEY=***

# eRx
ERX_API_BASE_URL=***

# Identity Provider (for staff SSO)
IDENTITY_PROVIDER_ISSUER_URL=***

# =============================================================================
# Security
# =============================================================================

# CORS origins (comma-separated)
CORS_ORIGINS=https://app.concierge-os.example.com,https://admin.concierge-os.example.com

# Webhook signing secret
WEBHOOK_SECRET=***

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# Session
SESSION_TIMEOUT_SECONDS=3600
SESSION_REFRESH_WINDOW_SECONDS=300

# =============================================================================
# Monitoring
# =============================================================================

# Sentry or similar error tracking
SENTRY_DSN=***

# CloudWatch or similar metrics
METRICS_ENABLED=true
METRICS_NAMESPACE=ConciergeOS

# Health check
HEALTH_CHECK_TIMEOUT_SECONDS=5

# =============================================================================
# Backup
# =============================================================================

# Automated backup settings
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 3 * * *  # Daily at 3 AM

# =============================================================================
# Feature Flags
# =============================================================================

# Use sandbox adapters instead of real vendors (for testing)
USE_SANDBOX_ADAPTERS=false

# Enable/disable features
ENABLE_AI_ASSISTANT=true
ENABLE_PATIENT_PORTAL=true
ENABLE_BILLING_AUTOMATION=true

# =============================================================================
# Compliance
# =============================================================================

# HIPAA audit log retention
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years

# Minimum password requirements
MIN_PASSWORD_LENGTH=12
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_REQUIRE_NUMBERS=true

# MFA settings
MFA_ENFORCED=true
MFA_GRACE_PERIOD_DAYS=7
