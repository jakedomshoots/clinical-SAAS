APP_ENV=production
DATABASE_URL=postgresql+asyncpg://concierge:<password>@<host>:5432/concierge_os
REDIS_URL=rediss://:<password>@<host>:6379/0

SECRET_KEY=<generate-64-random-characters>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=https://app.example-clinic.com

AUTO_CREATE_SCHEMA=false
ENSURE_OBJECT_STORAGE_ON_STARTUP=true
ALLOW_SEED_ENDPOINT=false

MINIO_ENDPOINT=<s3-or-minio-host>
MINIO_ACCESS_KEY=<production-access-key>
MINIO_SECRET_KEY=<production-secret-key>
MINIO_BUCKET=concierge-os
MINIO_SECURE=true

EHR_API_BASE_URL=<ehr-api-base-url>
FAX_PROVIDER_API_KEY=<fax-provider-api-key>
PORTAL_API_BASE_URL=<portal-api-base-url>
CALENDAR_API_BASE_URL=<calendar-api-base-url>
COPILOTKIT_RUNTIME_URL=<copilotkit-runtime-url>
COMMUNICATIONS_PROVIDER=twilio-or-sendgrid-or-portal
COMMUNICATIONS_PROVIDER_API_KEY=<communications-provider-api-key>
CLEARINGHOUSE_API_BASE_URL=<clearinghouse-api-base-url>
CLEARINGHOUSE_API_KEY=<clearinghouse-api-key>
WEBHOOK_SHARED_SECRET=<webhook-secret>
